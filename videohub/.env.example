# Copier en .env (chmod 600, NON commité) et remplir.
# Génère le token : python -c 'import secrets; print(secrets.token_urlsafe(32))'
LINKUP_VIDEOHUB_SERVICE_TOKEN=change-me-to-a-random-32-bytes-base64

# Clé API Google Gemini (palier GRATUIT) — https://aistudio.google.com/apikey
# Laisser vide pour désactiver le formatage IA (repli heuristique seul).
LINKUP_VIDEOHUB_GEMINI_API_KEY=

# Optionnels (valeurs par défaut dans config.py)
# LINKUP_VIDEOHUB_HOST=127.0.0.1
# LINKUP_VIDEOHUB_PORT=8780
# LINKUP_VIDEOHUB_RATE_LIMIT_PER_MIN=20
# LINKUP_VIDEOHUB_MAX_DOWNLOAD_MB=512
