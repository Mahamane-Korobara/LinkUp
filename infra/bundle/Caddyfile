{
	# FrankenPHP intégré + pas de HTTPS auto (LAN local, le tél vise http://ip:8000).
	frankenphp
	auto_https off
	admin off
}

:{$LINKUP_HTTP_PORT:8000} {
	# 1) API + temps réel Laravel → front controller PHP (public/index.php).
	@laravel path /api/* /broadcasting/* /sanctum/* /up
	handle @laravel {
		root * {$LINKUP_AGENT_PUBLIC}
		php_server
	}

	# 2) Tout le reste = dashboard statique (export Next). try_files gère les
	#    routes /devices, /files… (export produit devices.html, etc.).
	handle {
		root * {$LINKUP_DASHBOARD_OUT}
		try_files {path} {path}.html {path}/index.html /index.html
		file_server
	}
}
