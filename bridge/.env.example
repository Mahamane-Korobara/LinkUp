# Linkup bridge — configuration
#
# IMPORTANT — sécurité :
# LINKUP_BRIDGE_AGENT_TOKEN doit être CHANGÉ avant le premier démarrage.
# Le bridge refuse de démarrer si on laisse la valeur placeholder.
# Génère-en un nouveau via :
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Et reporte la MÊME valeur dans agent/.env (LINKUP_BRIDGE_AGENT_TOKEN).

LINKUP_BRIDGE_HOST=0.0.0.0
LINKUP_BRIDGE_PORT=8765
LINKUP_BRIDGE_REVERB_PORT=8080
LINKUP_BRIDGE_AGENT_TOKEN=change-me-to-a-random-32-bytes-base64
LINKUP_BRIDGE_TRANSFERS_DIR=~/Linkup/Inbox
LINKUP_BRIDGE_DOWNLOADS_DIR=~/Linkup/Downloads
LINKUP_BRIDGE_LOG_LEVEL=INFO
LINKUP_BRIDGE_MDNS_HEARTBEAT_INTERVAL_SECONDS=5
LINKUP_BRIDGE_MDNS_STALE_AFTER_SECONDS=15
LINKUP_BRIDGE_MDNS_HEALTHCHECK_TIMEOUT_SECONDS=2
